# Auto-detect text files and normalize to LF in the repository
* text=auto

# Python source
*.py text eol=lf

# Jupyter notebooks
*.ipynb text eol=lf

# Markdown
*.md text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows batch files
*.bat text eol=crlf
*.ps1 text eol=crlf

# Hide ipynb from language stats
*.ipynb linguist-vendored